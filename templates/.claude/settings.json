{
  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" },
  "hooks": {
    "Stop": [{"matcher": "", "hooks": [{"type": "command", "command": "bash .claude/hooks/stop.sh"}]}],
    "PreToolUse": [{"matcher": "Bash", "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-tool.sh"}]}]
  },
  "permissions": {
    "allow": ["Bash(git:*)", "Bash(find:*)", "Bash(grep:*)", "Bash(cat:*)", "Bash(ls:*)"],
    "deny": ["Bash(rm -rf *)", "Bash(git push *)"]
  }
}
