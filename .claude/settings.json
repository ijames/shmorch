{
  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" },
  "hooks": {
    "SessionStart": [{"matcher": "", "hooks": [{"type": "command", "command": "bash .claude/hooks/session-start.sh 2>/dev/null || true"}]}],
    "Stop": [{"matcher": "", "hooks": [{"type": "command", "command": "bash ~/.claude/skills/shmorch/tools/stop.sh"}]}],
    "PreToolUse": [{"matcher": "Bash", "hooks": [{"type": "command", "command": "bash .claude/hooks/pre-tool.sh 2>/dev/null || true"}]}]
  },
  "permissions": {
    "allow": ["Bash(git:*)", "Bash(find:*)", "Bash(grep:*)", "Bash(cat:*)", "Bash(ls:*)"],
    "deny": ["Bash(rm -rf *)", "Bash(git push --force* * main)", "Bash(git push --force* * master)", "Bash(git push * main)", "Bash(git push * master)"],
    "ask": ["Bash(git push --force*)"]
  }
}
